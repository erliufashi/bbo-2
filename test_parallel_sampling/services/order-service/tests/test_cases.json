            "price": 49.99
          },
          {
            "product_id": "prod-789",
            "quantity": 1,
            "price": 29.99
          }
        ],
        "shipping_address": {
          "street": "123 Main St",
          "city": "San Francisco",
          "zip": "94105"
        }
      }
    },
    "expected": {
